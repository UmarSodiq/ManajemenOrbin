rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isBendahara() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'bendahara';
    }

    function isSekretaris() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'sekretaris';
    }

    function isAnggota() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'anggota';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'role', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 50 &&
             data.role in ['bendahara', 'sekretaris', 'anggota'] &&
             data.createdAt == request.time;
    }

    function isValidAnggota(data) {
      return data.keys().hasAll(['namaLengkap', 'jabatan', 'status', 'tanggalBergabung']) &&
             data.keys().size() <= 7 &&
             data.namaLengkap is string && data.namaLengkap.size() >= 1 && data.namaLengkap.size() <= 100 &&
             data.jabatan is string && data.jabatan.size() >= 1 && data.jabatan.size() <= 100 &&
             data.status in ['aktif', 'nonaktif'] &&
             data.tanggalBergabung is timestamp &&
             (!data.keys().hasAll(['userId']) || data.userId is string) &&
             (!data.keys().hasAll(['fotoUrl']) || (data.fotoUrl is string && data.fotoUrl.size() <= 1000000)) &&
             (!data.keys().hasAll(['noTelp']) || (data.noTelp is string && data.noTelp.size() <= 20));
    }

    function isValidIuran(data) {
      return data.keys().hasAll(['anggotaId', 'periode', 'jumlah', 'tanggalBayar', 'dicatatOleh']) &&
             data.keys().size() == 5 &&
             isValidId(data.anggotaId) &&
             data.periode is string && data.periode.matches('^\\d{4}-\\d{2}$') &&
             data.jumlah is number &&
             data.tanggalBayar == request.time &&
             data.dicatatOleh == request.auth.uid;
    }

    function isValidTransaksi(data) {
      return data.keys().hasAll(['keterangan', 'jumlah', 'tanggal', 'dicatatOleh']) &&
             (data.keys().size() == 4 || (data.keys().size() == 5 && data.keys().hasAll(['isIuran']))) &&
             data.keterangan is string && data.keterangan.size() >= 1 && data.keterangan.size() <= 255 &&
             data.jumlah is number && data.jumlah >= 0.01 && data.jumlah <= 999999999.99 &&
             data.tanggal is timestamp &&
             data.dicatatOleh is string &&
             (!data.keys().hasAll(['isIuran']) || data.isIuran is bool);
    }

    function isValidRapat(data) {
      return data.judul is string && 
             data.tanggal is timestamp &&
             data.waktuMulai is string &&
             data.waktuSelesai is string &&
             data.tempat is string &&
             (!data.keys().contains('dibuatOleh') || data.dibuatOleh is string);
    }

    function isValidPresensi(data) {
      return data.keys().hasAll(['rapatId', 'anggotaId', 'status', 'dicatatOleh']) &&
             isValidId(data.rapatId) &&
             isValidId(data.anggotaId) &&
             data.status in ['hadir', 'tidak_hadir'] &&
             data.dicatatOleh is string;
    }

    function isValidPengumuman(data) {
      return data.keys().hasAll(['judul', 'isi', 'tanggalDibuat', 'tanggalDiperbarui', 'dibuatOleh']) &&
             data.keys().size() == 5 &&
             data.judul is string && data.judul.size() >= 1 && data.judul.size() <= 100 &&
             data.isi is string && data.isi.size() >= 1 && data.isi.size() <= 2000 &&
             data.tanggalDibuat is timestamp &&
             data.tanggalDiperbarui is timestamp &&
             data.dibuatOleh is string;
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['namaBarang', 'lokasi', 'tanggalInput', 'dicatatOleh']) &&
             data.keys().size() == 4 &&
             data.namaBarang is string && data.namaBarang.size() >= 1 && data.namaBarang.size() <= 100 &&
             data.lokasi is string && data.lokasi.size() >= 1 && data.lokasi.size() <= 100 &&
             data.tanggalInput is timestamp &&
             data.dicatatOleh is string;
    }

    function isValidGallery(data) {
      return data.keys().hasAll(['judul', 'imageUrl', 'tanggalKegiatan', 'tanggalUpload', 'diunggahOleh']) &&
             data.keys().size() <= 6 &&
             data.judul is string && data.judul.size() >= 1 && data.judul.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() >= 1 && data.imageUrl.size() <= 1000 &&
             data.tanggalKegiatan is string &&
             data.tanggalUpload is timestamp &&
             data.diunggahOleh is string &&
             (!data.keys().contains('deskripsi') || (data.deskripsi is string && data.deskripsi.size() <= 500));
    }

    function isValidKegiatan(data) {
      return data.keys().hasAll(['judul', 'kategori', 'tanggal', 'dibuatOleh']) &&
             data.keys().size() <= 8 &&
             data.judul is string && data.judul.size() >= 1 && data.judul.size() <= 100 &&
             data.kategori in ['Rutin', 'Khusus', 'Sosial', 'Rapat'] &&
             data.tanggal is string &&
             data.dibuatOleh is string &&
             (!data.keys().contains('deskripsi') || (data.deskripsi is string && data.deskripsi.size() <= 500)) &&
             (!data.keys().contains('laporanNarasi') || (data.laporanNarasi is string && data.laporanNarasi.size() <= 5000)) &&
             (!data.keys().contains('biayaAktual') || (data.biayaAktual is number)) &&
             (!data.keys().contains('catatanKeuangan') || (data.catatanKeuangan is string && data.catatanKeuangan.size() <= 1000));
    }

    function isValidAnggaran(data) {
      return data.keys().hasAll(['judul', 'jumlahDibutuhkan', 'status', 'tanggalPengajuan', 'diajukanOleh']) &&
             data.keys().size() <= 7 &&
             data.judul is string && data.judul.size() >= 1 && data.judul.size() <= 100 &&
             data.jumlahDibutuhkan is number &&
             data.status in ['Menunggu', 'Disetujui', 'Ditolak', 'Cair'] &&
             data.tanggalPengajuan is timestamp &&
             data.diajukanOleh is string &&
             (!data.keys().contains('deskripsi') || (data.deskripsi is string && data.deskripsi.size() <= 1000)) &&
             (!data.keys().contains('catatanBendahara') || (data.catatanBendahara is string && data.catatanBendahara.size() <= 500));
    }

    function isValidPolling(data) {
      return data.keys().hasAll(['judul', 'tipe', 'status', 'createdAt', 'dibuatOleh']) &&
             data.keys().size() <= 7 &&
             data.judul is string && data.judul.size() >= 1 && data.judul.size() <= 200 &&
             data.tipe in ['pilihan_ganda', 'manual'] &&
             data.status in ['aktif', 'selesai'] &&
             data.createdAt is timestamp &&
             data.dibuatOleh is string &&
             (!data.keys().contains('deskripsi') || (data.deskripsi is string && data.deskripsi.size() <= 1000)) &&
             (!data.keys().contains('pilihan') || (data.pilihan is list && data.pilihan.size() <= 20));
    }

    function isValidVote(data) {
      return data.keys().hasAll(['pilihan', 'timestamp']) &&
             data.keys().size() <= 3 &&
             data.pilihan is string && data.pilihan.size() >= 1 && data.pilihan.size() <= 200 &&
             data.timestamp == request.time &&
             (!data.keys().contains('voterName') || (data.voterName is string && data.voterName.size() <= 100));
    }

    function isValidGameScore(data) {
      return data.keys().hasAll(['userId', 'namaLengkap', 'score', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.namaLengkap is string && data.namaLengkap.size() >= 1 && data.namaLengkap.size() <= 100 &&
             data.score is number && data.score >= 0 &&
             data.timestamp == request.time;
    }

    function isValidGameRoom(data) {
      return data.keys().hasAll(['gameType', 'status', 'players', 'updatedAt']) &&
             data.gameType is string &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.players is map &&
             data.updatedAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid;
      // No updates for role allowed by user themselves
    }

    match /anggota/{anggotaId} {
      allow read: if isSignedIn();
      allow create: if isSekretaris();
      allow update: if isSekretaris() || (
        isSignedIn() && 
        (resource.data.userId == request.auth.uid || anggotaId == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['namaLengkap', 'noTelp', 'fotoUrl'])
      );
      allow delete: if isSekretaris();
    }

    match /iuran/{iuranId} {
      allow read: if isSignedIn();
      allow create: if isBendahara();
      allow delete: if isBendahara();
    }

    match /kasMasuk/{kasMasukId} {
      allow read: if isSignedIn();
      allow create: if isBendahara();
      allow update: if isBendahara();
      allow delete: if isBendahara();
    }

    match /kasKeluar/{kasKeluarId} {
      allow read: if isSignedIn();
      allow create: if isBendahara();
      allow update: if isBendahara();
      allow delete: if isBendahara();
    }

    match /rapat/{rapatId} {
      allow read: if isSignedIn();
      allow create: if isSekretaris();
      allow update: if isSekretaris();
      allow delete: if isSekretaris();
    }

    match /presensi/{presensiId} {
      allow read: if isSignedIn();
      allow create: if isSekretaris();
      allow update: if isSekretaris();
      allow delete: if isSekretaris();
    }

    match /pengumuman/{pengumumanId} {
      allow read: if isSignedIn();
      allow create: if isSekretaris();
      allow update: if isSekretaris();
      allow delete: if isSekretaris();
    }

    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow create: if isSekretaris();
      allow update: if isSekretaris();
      allow delete: if isSekretaris();
    }

    match /galeri/{photoId} {
      allow read: if isSignedIn();
      allow create: if (isSekretaris() || isBendahara());
      allow update: if (isSekretaris() || isBendahara());
      allow delete: if (isSekretaris() || isBendahara());
    }

    match /kegiatan/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSekretaris();
      allow update: if isSekretaris() || (isBendahara() && incoming().diff(existing()).affectedKeys().hasOnly(['biayaAktual', 'catatanKeuangan']));
      allow delete: if isSekretaris();
    }
    
    match /polling/{pollId} {
      allow read: if true;
      allow create: if isSekretaris();
      allow update: if isSekretaris();
      allow delete: if isSekretaris();

      match /voters/{voterId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && voterId == request.auth.uid && get(/databases/$(database)/documents/polling/$(pollId)).data.status == 'aktif';
      }
    }

    match /gameScores/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && userId == request.auth.uid && isValidGameScore(incoming());
    }

    match /gameRooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidGameRoom(incoming());
      allow update: if isSignedIn() && (
        (
          incoming().players.p1.uid == request.auth.uid || 
          incoming().players.p2.uid == request.auth.uid ||
          (incoming().players.keys().contains('p3') && incoming().players.p3.uid == request.auth.uid) ||
          (incoming().players.keys().contains('p4') && incoming().players.p4.uid == request.auth.uid)
        ) &&
        isValidGameRoom(incoming())
      );
      allow delete: if false;
    }
  }
}
