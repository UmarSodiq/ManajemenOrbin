{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["bendahara", "sekretaris"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "role", "createdAt"]
    },
    "Anggota": {
      "title": "Anggota",
      "description": "Organization member",
      "type": "object",
      "properties": {
        "namaLengkap": { "type": "string" },
        "jabatan": { "type": "string" },
        "status": { "type": "string", "enum": ["aktif", "nonaktif"] },
        "tanggalBergabung": { "type": "string", "format": "date-time" }
      },
      "required": ["namaLengkap", "jabatan", "status", "tanggalBergabung"]
    },
    "Iuran": {
      "title": "Iuran",
      "description": "Member dues payment",
      "type": "object",
      "properties": {
        "anggotaId": { "type": "string" },
        "periode": { "type": "string" },
        "tanggalBayar": { "type": "string", "format": "date-time" },
        "dicatatOleh": { "type": "string" }
      },
      "required": ["anggotaId", "periode", "tanggalBayar", "dicatatOleh"]
    },
    "KasMasuk": {
      "title": "Kas Masuk",
      "description": "Income transaction",
      "type": "object",
      "properties": {
        "keterangan": { "type": "string" },
        "jumlah": { "type": "number" },
        "tanggal": { "type": "string", "format": "date-time" },
        "dicatatOleh": { "type": "string" }
      },
      "required": ["keterangan", "jumlah", "tanggal", "dicatatOleh"]
    },
    "KasKeluar": {
      "title": "Kas Keluar",
      "description": "Expense transaction",
      "type": "object",
      "properties": {
        "keterangan": { "type": "string" },
        "jumlah": { "type": "number" },
        "tanggal": { "type": "string", "format": "date-time" },
        "dicatatOleh": { "type": "string" }
      },
      "required": ["keterangan", "jumlah", "tanggal", "dicatatOleh"]
    },
    "Rapat": {
      "title": "Rapat",
      "description": "Meeting record",
      "type": "object",
      "properties": {
        "judul": { "type": "string" },
        "tanggal": { "type": "string", "format": "date-time" },
        "waktuMulai": { "type": "string" },
        "waktuSelesai": { "type": "string" },
        "tempat": { "type": "string" },
        "dibuatOleh": { "type": "string" }
      },
      "required": ["judul", "tanggal", "waktuMulai", "waktuSelesai", "tempat", "dibuatOleh"]
    },
    "Presensi": {
      "title": "Presensi",
      "description": "Attendance record per meeting",
      "type": "object",
      "properties": {
        "rapatId": { "type": "string" },
        "anggotaId": { "type": "string" },
        "status": { "type": "string", "enum": ["hadir", "tidak_hadir"] },
        "dicatatOleh": { "type": "string" }
      },
      "required": ["rapatId", "anggotaId", "status", "dicatatOleh"]
    },
    "Pengumuman": {
      "title": "Pengumuman",
      "description": "Organization announcement",
      "type": "object",
      "properties": {
        "judul": { "type": "string" },
        "isi": { "type": "string" },
        "tanggalDibuat": { "type": "string", "format": "date-time" },
        "tanggalDiperbarui": { "type": "string", "format": "date-time" },
        "dibuatOleh": { "type": "string" }
      },
      "required": ["judul", "isi", "tanggalDibuat", "tanggalDiperbarui", "dibuatOleh"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Organization asset/property",
      "type": "object",
      "properties": {
        "namaBarang": { "type": "string" },
        "lokasi": { "type": "string" },
        "tanggalInput": { "type": "string", "format": "date-time" },
        "dicatatOleh": { "type": "string" }
      },
      "required": ["namaBarang", "lokasi", "tanggalInput", "dicatatOleh"]
    },
    "Galeri": {
      "title": "Galeri",
      "description": "Activity documentation photos",
      "type": "object",
      "properties": {
        "judul": { "type": "string" },
        "deskripsi": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tanggalKegiatan": { "type": "string", "format": "date" },
        "tanggalUpload": { "type": "string", "format": "date-time" },
        "diunggahOleh": { "type": "string" }
      },
      "required": ["judul", "imageUrl", "tanggalKegiatan", "tanggalUpload", "diunggahOleh"]
    },
    "Kegiatan": {
      "title": "Kegiatan",
      "description": "Calendar event with integrated reporting",
      "type": "object",
      "properties": {
        "judul": { "type": "string" },
        "kategori": { "type": "string", "enum": ["Rutin", "Khusus", "Sosial", "Rapat"] },
        "deskripsi": { "type": "string" },
        "tanggal": { "type": "string", "format": "date" },
        "dibuatOleh": { "type": "string" },
        "laporanNarasi": { "type": "string" },
        "biayaAktual": { "type": "number" },
        "catatanKeuangan": { "type": "string" }
      },
      "required": ["judul", "kategori", "tanggal", "dibuatOleh"]
    },
    "Polling": {
      "title": "Polling",
      "description": "Electronic voting or polling",
      "type": "object",
      "properties": {
        "judul": { "type": "string" },
        "deskripsi": { "type": "string" },
        "tipe": { "type": "string", "enum": ["pilihan_ganda", "manual"] },
        "pilihan": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["aktif", "selesai"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "dibuatOleh": { "type": "string" }
      },
      "required": ["judul", "tipe", "status", "createdAt", "dibuatOleh"]
    },
    "Vote": {
      "title": "Vote",
      "description": "User vote record",
      "type": "object",
      "properties": {
        "pilihan": { "type": "string" },
        "voterName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["pilihan", "timestamp"]
    },
    "GameScore": {
      "title": "Game Score",
      "description": "Orbin Star Collector high scores",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "namaLengkap": { "type": "string" },
        "score": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "namaLengkap", "score", "timestamp"]
    },
    "GameRoom": {
      "title": "Game Room",
      "description": "Multiplayer game session",
      "type": "object",
      "properties": {
        "gameType": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "players": { 
          "type": "object",
          "properties": {
            "p1": { "type": "object", "properties": { "uid": { "type": "string" }, "name": { "type": "string" } } },
            "p2": { "type": "object", "properties": { "uid": { "type": "string" }, "name": { "type": "string" } } }
          }
        },
        "gameState": { "type": "object" },
        "turn": { "type": "string" },
        "winner": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["gameType", "status", "players", "updatedAt"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "anggota": { "schema": "Anggota", "description": "Members" },
    "iuran": { "schema": "Iuran", "description": "Member dues" },
    "kasMasuk": { "schema": "KasMasuk", "description": "Income records" },
    "kasKeluar": { "schema": "KasKeluar", "description": "Expense records" },
    "rapat": { "schema": "Rapat", "description": "Meeting records" },
    "presensi": { "schema": "Presensi", "description": "Attendance records" },
    "pengumuman": { "schema": "Pengumuman", "description": "Announcements" },
    "assets": { "schema": "Asset", "description": "Organization assets" },
    "galeri": { "schema": "Galeri", "description": "Activity documentation" },
    "kegiatan": { "schema": "Kegiatan", "description": "Calendar events" },
    "polling": { "schema": "Polling", "description": "Polls and voting" },
    "polling/{pollId}/voters": { "schema": "Vote", "description": "Votes cast in a poll" },
    "gameScores": { "schema": "GameScore", "description": "Game high scores" },
    "gameRooms": { "schema": "GameRoom", "description": "Active multiplayer game sessions" }
  }
}
